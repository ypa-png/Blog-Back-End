<!DOCTYPE generatorConfiguration PUBLIC
        "-//mybatis.org//DTD MyBatis Generator Configuration 1.0//EN"
        "http://mybatis.org/dtd/mybatis-generator-config_1_0.dtd">
<generatorConfiguration>
    <context id="simple" targetRuntime="MyBatis3">

        <!--消除逆向生成的注释-->
        <commentGenerator>
            <property name="suppressAllComments" value="true"/>
        </commentGenerator>

        <jdbcConnection driverClass="com.mysql.cj.jdbc.Driver"
                        connectionURL="jdbc:mysql://localhost:3306/chengxuba?serverTimezone=Asia/Shanghai&amp;useUnicode=true;&amp;characterEncoding=utf-8"
                        userId="root"
                        password="123456"/>

        <javaModelGenerator targetPackage="top.yangbq.pojo" targetProject="src/main/java"/>

        <sqlMapGenerator targetPackage="top.yangbq.mapper" targetProject="src/main/resources"/>

        <javaClientGenerator type="XMLMAPPER" targetPackage="top.yangbq.mapper" targetProject="src/main/java"/>

<!--        <table tableName="users"/>-->
        <table tableName="article_image"/>

    </context>
</generatorConfiguration>